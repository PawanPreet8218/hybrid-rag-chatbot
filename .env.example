# Copy this file to .env and fill in your key. NEVER commit the real .env.

# ---- Required ----
GROQ_API_KEY=your_groq_api_key_here

# ---- Optional overrides (all app settings use the SAGE_ prefix) ----
# Anything in sage.config.Settings can be overridden here. Examples:
# SAGE_USER=Gurri
# SAGE_DATA_DIR=/data            # where the index / chats / uploads are persisted
# SAGE_LLM_MODEL=llama-3.3-70b-versatile
# SAGE_CHUNK_SIZE=800
# SAGE_CHUNK_OVERLAP=150
# SAGE_RERANK_TOP_N=5
# SAGE_MAX_UPLOAD_MB=50
# SAGE_LOG_LEVEL=INFO
# SAGE_LOG_JSON=false            # true -> structured JSON logs (prod)
